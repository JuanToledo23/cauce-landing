---
interface Props {
  abVariant: 'A' | 'B' | 'C';
}

const { abVariant } = Astro.props;
import { heroVariants } from '../data/ab-variants';
const defaultVariant = heroVariants[abVariant] || heroVariants['A'];
---

<section id="hero" class="hero-bg pt-20 pb-20 px-5 lg:px-16 relative overflow-hidden">

  <!-- Logo SVG ambiental de fondo — parallax con scroll -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" style="z-index: 0" aria-hidden="true">
    <svg
      id="hero-bg-logo"
      viewBox="0 0 110 193"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="absolute hidden lg:block"
      style="right: -2%; top: 15%; height: 90vh; width: auto; opacity: 0.05; transition: transform 0.1s linear"
    >
      <path d="M92.8125 96.25L23.2031 179.605L23.2031 12.8951L92.8125 96.25Z" fill="#F8F7F4"/>
      <path d="M110 96L61.25 140.167L61.25 51.8327L110 96Z" fill="#1D9E75" style="opacity: 0.4"/>
    </svg>
  </div>

  <div class="max-w-4xl mx-auto relative" style="z-index: 1">

    <!-- Label -->
    <p class="type-label hero-animate" style="color: #7A8C82; animation-delay: 0ms">
      CONSULTORA DE PRODUCTO DIGITAL Y MARCA · CDMX
    </p>

    <!-- Statement principal A/B -->
    <h1
      id="hero-statement"
      class="type-display hero-animate"
      style="color: #F8F7F4; animation-delay: 100ms"
      data-variant={abVariant}
    >
      {defaultVariant.statement.map(line => <span class="block">{line}</span>)}
    </h1>

    <p
      id="hero-sub"
      class="type-body-lg mt-6 max-w-[460px] hero-animate"
      style="color: #7A8C82; animation-delay: 220ms"
    >
      {defaultVariant.subStatement}
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col gap-4 lg:flex-row lg:items-center hero-animate" style="animation-delay: 340ms">
      <a
        href="#auditoria"
        id="hero-cta"
        class="type-cta inline-flex items-center justify-center
               bg-[#1D9E75] text-white rounded-none px-8 h-14
               hover:bg-[#178A65] active:scale-[0.98] transition-all duration-150
               lg:w-auto focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#1D9E75]"
      >
        Quiero mi diagnóstico gratuito
      </a>
      <a
        href="#etapas"
        id="hero-whatsapp"
        class="type-cta inline-flex items-center justify-center
               border text-white rounded-none px-8 h-14
               hover:bg-white/10 active:scale-[0.98] transition-all duration-150
               lg:w-auto focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#1D9E75]"
        style="border-color: #F8F7F4"
      >
        ¿Qué proyecto necesito?
      </a>
    </div>

    <!-- Separador + prueba social -->
    <div class="hero-animate" style="animation-delay: 460ms">
      <div class="mt-10 border-t" style="border-color: #1E3D2E"></div>
      <div class="mt-6">
        <p class="type-small" style="color: #4A5C52">
          <!-- Han confiado en el equipo: <span style="color: #3A6B52">MAJA Sportswear · BrightPath · Klu · New Era Latam</span> -->
          Research primero · Especificación · Construcción acelerada
        </p>
      </div>
    </div>

  </div>
</section>

<script>
  import { heroVariants } from '../data/ab-variants';
  import { trackEvent } from '../utils/analytics';

  document.addEventListener('ab:ready', ((e: Event) => {
    const variant = (e as CustomEvent).detail.variant as 'A' | 'B' | 'C';
    const data = heroVariants[variant];
    if (!data) return;

    const el = document.getElementById('hero-statement');
    if (el) {
      el.innerHTML = data.statement.map(l => `<span class="block">${l}</span>`).join('');
      el.dataset.variant = variant;
    }

    const sub = document.getElementById('hero-sub');
    if (sub) sub.textContent = data.subStatement;
  }) as EventListener);

  document.getElementById('hero-cta')?.addEventListener('click', () => {
    const variant = document.getElementById('hero-statement')?.dataset.variant || 'A';
    trackEvent('hero_cta_click', { ab_variant: variant, cta_location: 'hero' });
  });

  document.getElementById('hero-whatsapp')?.addEventListener('click', () => {
    const variant = document.getElementById('hero-statement')?.dataset.variant || 'A';
    trackEvent('whatsapp_click', { ab_variant: variant, cta_location: 'hero' });
  });

  // Parallax: el logo de fondo se mueve más lento que el scroll
  const bgLogo = document.getElementById('hero-bg-logo');
  if (bgLogo) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      bgLogo.style.transform = `translateX(${y * -0.15}px)`;
    }, { passive: true });
  }
</script>