---
const pasos = [
  {
    num: '01',
    title: 'Research primero',
    body: 'Entendemos el problema antes de diseñar o construir. Aplica igual para un sitio de una página que para una plataforma compleja.'
  },
  {
    num: '02',
    title: 'Especificación',
    body: 'Todo documentado antes de empezar. Qué se construye, cómo se mide, qué queda fuera. Sin sorpresas ni costos que explotan.'
  },
  {
    num: '03',
    title: 'Construcción acelerada',
    body: 'Equipo completo, entregas visibles. Un sitio en 2 semanas. Un MVP en 6. Sin trimestres de silencio.'
  },
];
---

<section id="como-trabajamos" class="pt-16 pb-16 px-5 lg:px-16" style="background-color: #0D1F17; color: #F8F7F4">
  <div class="max-w-screen-xl mx-auto">

    <h2 class="type-h2 mb-12 reveal-element" style="color: #F8F7F4">
      Tres pasos. En ese orden.
    </h2>

    <div class="flex flex-col gap-12 lg:grid lg:grid-cols-3 lg:gap-8 reveal-stagger">
      {pasos.map(paso => (
        <div class="reveal-element">
          <span class="type-display block reveal-number" style="color: #1D9E75" aria-hidden="true">{paso.num}</span>
          <h3 class="type-h3 mt-2" style="color: #F8F7F4">{paso.title}</h3>
          <p class="type-body mt-3 max-w-[320px] lg:max-w-none" style="color: #B8D4C8">{paso.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
