---
const etapas = [
  {
    title: 'Estoy empezando',
    description: 'Negocio sin presencia digital todavía',
  },
  {
    title: 'Tengo sitio, pero no funciona',
    description: 'Está online pero no llegan clientes',
  },
  {
    title: 'Necesito automatizar',
    description: 'Los procesos manuales ya no escalan',
  },
  {
    title: 'Quiero construir un producto',
    description: 'Tengo una idea de app o plataforma',
  },
];
---

<section id="etapas" class="pt-16 pb-16 px-5 lg:px-16">
  <div class="max-w-screen-xl mx-auto reveal-stagger">

    <h2 class="type-h2 reveal-element" style="color: #0A0A0A">
      ¿En qué etapa está tu negocio?
    </h2>
    <p class="type-body-lg mt-4 reveal-element" style="color: #4A4A4A">
      Selecciona tu perfil y te decimos exactamente qué podemos construir juntos.
    </p>

    <div class="mt-8 grid grid-cols-1 gap-4 lg:grid-cols-2 lg:gap-6 reveal-element">
      {etapas.map(etapa => (
        <div class="border p-5 rounded-none card-lift" style="border-color: #E0DDD6">
          <p class="type-h3" style="color: #0A0A0A">{etapa.title}</p>
          <p class="type-body mt-1" style="color: #1D9E75">{etapa.description}</p>
        </div>
      ))}
    </div>

    <p class="type-body mt-6 reveal-element" style="color: #4A4A4A">
      Selecciona tu perfil para ver qué podemos hacer por ti.
    </p>

  </div>
</section>
